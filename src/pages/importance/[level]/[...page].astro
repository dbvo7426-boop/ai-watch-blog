---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import Pagination from '../../../components/Pagination.astro';
import ImportanceFilter from '../../../components/ImportanceFilter.astro';
import { IMPORTANCE, PAGE_SIZE } from '../../../consts';

export async function getStaticPaths({ paginate }) {
  const posts = await getCollection(
    'posts',
    ({ data }) => (import.meta.env.PROD ? !data.draft : true)
  );

  return Object.keys(IMPORTANCE).flatMap((level) => {
    const levelPosts = posts
      .filter((post) => post.data.importance === level)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
    return paginate(levelPosts, { params: { level }, pageSize: PAGE_SIZE });
  });
}

const { level } = Astro.params;
const { page } = Astro.props;
const label = IMPORTANCE[level];
---

<BaseLayout title={`${label}の記事一覧`}>
  <div class="section-head" style="margin-top: 8px;">
    <h2>
      <span class={`importance-badge importance-${level}`} style="font-size: 14px; vertical-align: 3px; margin-right: 10px;">
        {label}
      </span>
      の記事一覧
    </h2>
    <span class="count">{page.total} 件</span>
  </div>

  <ImportanceFilter active={level} />

  <div class="grid">
    {page.data.map((post) => <ArticleCard post={post} />)}
  </div>

  {page.data.length === 0 && <p>該当する記事はまだありません。</p>}

  <Pagination page={page} />
</BaseLayout>
