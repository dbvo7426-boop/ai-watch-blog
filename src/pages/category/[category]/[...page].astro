---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import Pagination from '../../../components/Pagination.astro';
import ImportanceFilter from '../../../components/ImportanceFilter.astro';
import { CATEGORIES, PAGE_SIZE } from '../../../consts';

export async function getStaticPaths({ paginate }) {
  const posts = await getCollection(
    'posts',
    ({ data }) => (import.meta.env.PROD ? !data.draft : true)
  );

  return Object.keys(CATEGORIES).flatMap((category) => {
    const categoryPosts = posts
      .filter((post) => post.data.category === category)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
    return paginate(categoryPosts, { params: { category }, pageSize: PAGE_SIZE });
  });
}

const { category } = Astro.params;
const { page } = Astro.props;
const cat = CATEGORIES[category];
---

<BaseLayout title={`${cat.label}の記事一覧`}>
  <div class="section-head" style="margin-top: 8px;">
    <h2>
      <span class="badge" style={`background:${cat.color}; font-size: 14px; vertical-align: 3px; margin-right: 10px;`}>
        {cat.label}
      </span>
      の記事一覧
    </h2>
    <span class="count">{page.total} 件</span>
  </div>

  <ImportanceFilter />

  <div class="grid">
    {page.data.map((post) => <ArticleCard post={post} />)}
  </div>

  {page.data.length === 0 && <p>このカテゴリの記事はまだありません。</p>}

  <Pagination page={page} />
</BaseLayout>
