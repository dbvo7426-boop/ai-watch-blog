---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import MonitorStrip from '../components/MonitorStrip.astro';
import ArticleCard from '../components/ArticleCard.astro';
import BookmarkButton from '../components/BookmarkButton.astro';
import Pagination from '../components/Pagination.astro';
import { CATEGORIES, TYPES, IMPORTANCE, formatDate, PAGE_SIZE } from '../consts';

export async function getStaticPaths({ paginate }) {
  // 本番ビルドでは draft: true の記事を除外。devでは表示(DRAFTバッジ付き)
  const posts = (
    await getCollection('posts', ({ data }) =>
      import.meta.env.PROD ? !data.draft : true
    )
  ).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return paginate(posts, { pageSize: PAGE_SIZE });
}

const { page } = Astro.props;
const isFirstPage = page.currentPage === 1;

// 1ページ目だけ先頭記事を「注目記事」として大きく表示する
const featured = isFirstPage ? page.data[0] : null;
const rest = isFirstPage ? page.data.slice(1) : page.data;

const featuredCat = featured
  ? CATEGORIES[featured.data.category] ?? CATEGORIES.other
  : null;
const featuredImportance = featured ? IMPORTANCE[featured.data.importance] : null;
---

<BaseLayout>
  {isFirstPage && <MonitorStrip />}

  {
    featured && (
      <div class="card-wrap" data-slug={featured.id}>
        <a href={`/posts/${featured.id}/`} class="featured">
          <div class="meta">
            <span class="badge" style={`background:${featuredCat.color}`}>
              {featuredCat.label}
            </span>
            <span class="type-label">{TYPES[featured.data.type]}</span>
            <span class="date">{formatDate(featured.data.pubDate)}</span>
            {featured.data.draft && <span class="draft-flag">DRAFT</span>}
            <span class="read-flag">既読</span>
            {featuredImportance && (
              <span class={`importance-badge importance-${featured.data.importance}`}>
                {featuredImportance}
              </span>
            )}
          </div>
          <h1>{featured.data.title}</h1>
          <p>{featured.data.description}</p>
        </a>
        <BookmarkButton post={featured} />
      </div>
    )
  }

  <div class="section-head">
    <h2>{isFirstPage ? '最新記事' : `記事一覧`}</h2>
    <span class="count">{page.total} 件</span>
  </div>

  <div class="grid">
    {rest.map((post) => <ArticleCard post={post} />)}
  </div>

  {page.total === 0 && <p>まだ記事がありません。パイプラインの観測をお待ちください。</p>}

  <Pagination page={page} />
</BaseLayout>

<style>
  .featured {
    display: block;
    margin-top: 26px;
    background: var(--card);
    border: 1px solid var(--line);
    border-left: 6px solid var(--accent);
    border-radius: var(--radius);
    padding: 30px 34px;
    transition: border-color 0.15s ease;
  }
  .featured:hover {
    border-color: var(--accent);
  }
  .featured .meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }
  .featured h1 {
    margin: 0 0 10px;
    font-size: 26px;
  }
  .featured p {
    margin: 0;
    color: var(--muted);
    font-size: 15px;
  }
</style>
