---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookmarkButton from '../../components/BookmarkButton.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { CATEGORIES, TYPES, formatDate } from '../../consts';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  );

  return posts.map((post) => {
    const others = posts.filter((p) => p.id !== post.id);

    // 同カテゴリの記事を、タグの一致数→新しさの順に並べる
    const sameCategory = others
      .filter((p) => p.data.category === post.data.category)
      .map((p) => ({
        post: p,
        tagOverlap: p.data.tags.filter((t) => post.data.tags.includes(t)).length,
      }))
      .sort(
        (a, b) =>
          b.tagOverlap - a.tagOverlap || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf()
      )
      .map((r) => r.post);

    // 同カテゴリだけで4件に満たない場合は、他カテゴリの新着で補う
    const related = [...sameCategory];
    if (related.length < 4) {
      const usedIds = new Set([post.id, ...related.map((p) => p.id)]);
      const fallback = others
        .filter((p) => !usedIds.has(p.id))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
      related.push(...fallback.slice(0, 4 - related.length));
    }

    return {
      params: { slug: post.id },
      props: { post, related: related.slice(0, 4) },
    };
  });
}

const { post, related } = Astro.props;
const { Content } = await render(post);
const cat = CATEGORIES[post.data.category] ?? CATEGORIES.other;
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article data-current-slug={post.id}>
    <div class="head">
      <div class="meta">
        <a href={`/category/${post.data.category}/`} class="badge" style={`background:${cat.color}`}>
          {cat.label}
        </a>
        <span class="type-label">{TYPES[post.data.type]}</span>
        <span class="date">{formatDate(post.data.pubDate)}</span>
        {post.data.draft && <span class="draft-flag">DRAFT</span>}
        <BookmarkButton post={post} inline />
      </div>
      <h1>{post.data.title}</h1>
      {
        post.data.tags.length > 0 && (
          <p class="tags">
            {post.data.tags.map((tag) => (
              <a href={`/tags/${tag}/`} class="tag">#{tag}</a>
            ))}
          </p>
        )
      }
    </div>

    <div class="prose">
      <Content />

      {
        post.data.source && (
          <div class="source-box">
            <span class="src-label">一次情報</span>
            <a href={post.data.source} target="_blank" rel="noopener noreferrer">
              {post.data.source}
            </a>
          </div>
        )
      }
    </div>

    {
      related.length > 0 && (
        <div class="related">
          <div class="section-head">
            <h2>関連記事</h2>
            <a href={`/category/${post.data.category}/`} class="more-link">
              他の{cat.label}の記事を見る →
            </a>
          </div>
          <div class="grid">
            {related.map((r) => <ArticleCard post={r} />)}
          </div>
        </div>
      )
    }
  </article>
</BaseLayout>

<style>
  .head {
    margin-bottom: 26px;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  h1 {
    margin: 0;
    font-size: 28px;
  }
  .tags {
    margin: 12px 0 0;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--muted);
  }
  .tag:hover {
    color: var(--accent);
  }
  .related {
    margin-top: 48px;
  }
  .more-link {
    margin-left: auto;
    font-size: 13.5px;
    color: var(--muted);
    white-space: nowrap;
  }
  .more-link:hover {
    color: var(--accent);
  }
</style>
