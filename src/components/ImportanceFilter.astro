---
import { IMPORTANCE } from '../consts';
import { IMPORTANCE_EN } from '../consts.en';
import { t, prefix } from '../i18n';

interface Props {
  active?: string;
  lang?: string;
}

const { active, lang = 'ja' } = Astro.props;
const importance = lang === 'en' ? IMPORTANCE_EN : IMPORTANCE;
const ui = t(lang);
const base = prefix(lang);
---

<div class="importance-filter">
  <span class="filter-label">{ui.filterByImportance}</span>
  {
    Object.entries(importance).map(([level, label]) => (
      <a
        href={`${base}/importance/${level}/`}
        class:list={[`importance-badge importance-${level}`, { 'is-active': active === level }]}
      >
        {label}
      </a>
    ))
  }
</div>

<style>
  .importance-filter {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin: 16px 0 0;
  }
  .importance-filter .filter-label {
    font-size: 13px;
    color: var(--muted);
  }
  .importance-filter a.importance-badge {
    text-decoration: none;
  }
  .importance-filter a.importance-badge:hover {
    opacity: 0.75;
  }
  .importance-filter a.importance-badge.is-active {
    outline: 2px solid var(--ink);
    outline-offset: 1px;
  }
</style>
