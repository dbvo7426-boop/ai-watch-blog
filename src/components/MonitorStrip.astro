---
// サイトの"シグネチャ"要素: 観測ステータスバー
// ビルド時刻 = パイプラインが最後に動いた時刻(サイトは更新の度に再ビルドされるため)
import { t } from '../i18n';

interface Props {
  lang?: string;
}

const { lang = 'ja' } = Astro.props;
const ui = t(lang);
const built = new Date().toLocaleString(lang === 'en' ? 'en-US' : 'ja-JP', {
  timeZone: 'Asia/Tokyo',
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
  hour: '2-digit',
  minute: '2-digit',
});
---

<div class="monitor" role="status">
  <span class="label">{ui.observing}</span>
  <span class="built">{ui.lastObserved(built)}</span>
</div>

<style>
  .monitor {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 12.5px;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 10px 22px;
    color: var(--muted);
  }
  .label {
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.08em;
  }
  .built {
    margin-left: auto;
  }
  @media (max-width: 640px) {
    .built {
      margin-left: 0;
      width: 100%;
    }
  }
</style>
