---
import { SITE_TITLE } from '../consts';
import { SITE_TITLE_EN } from '../consts.en';
import { t, prefix } from '../i18n';

interface Props {
  lang?: string;
}

const { lang = 'ja' } = Astro.props;
const siteTitle = lang === 'en' ? SITE_TITLE_EN : SITE_TITLE;
const ui = t(lang);
const base = prefix(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container inner">
    <p class="note">
      {ui.footerNote}
    </p>
    <p class="copy">
      &copy; {year} {siteTitle} · <a href={`${base}/tags/`}>{ui.tagList}</a> · <a href={`${base}/rss.xml`}>{ui.rss}</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: #b8c0d0;
    margin-top: 40px;
  }
  .inner {
    padding-top: 28px;
    padding-bottom: 28px;
  }
  .note {
    font-size: 12.5px;
    line-height: 1.8;
    margin: 0 0 10px;
  }
  .copy {
    font-family: var(--font-mono);
    font-size: 12px;
    margin: 0;
  }
  .copy a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
