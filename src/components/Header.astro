---
import { SITE_TITLE, CATEGORIES } from '../consts';
import { SITE_TITLE_EN, CATEGORIES_EN } from '../consts.en';
import { t, prefix } from '../i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang?: string;
}

const { lang = 'ja' } = Astro.props;
const siteTitle = lang === 'en' ? SITE_TITLE_EN : SITE_TITLE;
const categories = lang === 'en' ? CATEGORIES_EN : CATEGORIES;
const ui = t(lang);
const base = prefix(lang);
---

<header class="site-header">
  <div class="container inner">
    <a href={`${base}/`} class="logo">
      <span class="dot" aria-hidden="true"></span>
      {siteTitle}
    </a>
    <nav aria-label="Category">
      {
        Object.entries(categories)
          .filter(([key]) => key !== 'other')
          .map(([key, cat]) => (
            <a href={`${base}/category/${key}/`} class="nav-link">
              <span class="cat-dot" style={`background:${cat.color}`} aria-hidden="true" />
              {cat.label}
            </a>
          ))
      }
      <a href={`${base}/bookmarks/`} class="nav-link bookmark-link">🔖 {ui.bookmarks}</a>
      <LanguageSwitcher lang={lang} />
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--ink);
    color: #fff;
  }
  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding-top: 16px;
    padding-bottom: 16px;
  }
  .logo {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 21px;
    letter-spacing: 0.03em;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
  }
  nav {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }
  .nav-link {
    font-size: 13.5px;
    font-weight: 500;
    opacity: 0.85;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .nav-link:hover {
    opacity: 1;
  }
  .cat-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
  }
  .bookmark-link {
    padding-left: 14px;
    border-left: 1px solid rgba(255, 255, 255, 0.25);
  }
</style>
